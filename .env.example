AZURE_FOUNDRY_ENDPOINT=https://<your-foundry-endpoint>
AZURE_FOUNDRY_API_KEY=<your-api-key>
AZURE_FOUNDRY_MODEL=<model-name>
PORT=4000

# Opcional: clave de Unsplash para mostrar imágenes reales del destino
# Regístrate gratis en https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=<your-unsplash-access-key>

# === NUEVAS VARIABLES PARA RAG (Opcional, activa el Historial y búsqueda semántica) ===
AZURE_EMBEDDING_ENDPOINT=https://<tu-openai-resource>.openai.azure.com
AZURE_EMBEDDING_API_KEY=<tu-embedding-api-key>
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

AZURE_SEARCH_ENDPOINT=https://<tu-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<tu-search-admin-key>
AZURE_SEARCH_INDEX=travel-plans
